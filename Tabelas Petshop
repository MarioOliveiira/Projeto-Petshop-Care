CREATE TABLE Animal(
	cod_animal SERIAL PRIMARY KEY,
	nome VARCHAR (100) NOT NULL,
	tipo_animal VARCHAR (50) NOT NULL
);

CREATE TABLE Cliente (
	cod_cliente SERIAL PRIMARY KEY,
	nome VARCHAR (100) NOT NULL,
	cpf VARCHAR (14) NOT NULL,
	email VARCHAR (150) NOT NULL,
	data_cadastro DATE NOT NULL
);

CREATE TABLE Produto (
	cod_produto SERIAL PRIMARY KEY,
	nome_produto VARCHAR (100) NOT NULL,
	ean VARCHAR (13) NOT NULL,
	dun VARCHAR (14) NOT NULL,
	descricao VARCHAR (140) NULL,
	marca VARCHAR (30) NOT NULL,
	categoria VARCHAR (30) NOT NULL
);

CREATE TABLE Empregado (
	cod_empregado SERIAL PRIMARY KEY,
	nome VARCHAR(100) NOT NULL,
	cargo VARCHAR(50) NOT NULL,
	cpf VARCHAR (14) NOT NULL,
	salario REAL NOT NULL,
	data_contratado DATE NOT NULL
);

CREATE TABLE Fornecedor (
	cod_fornecedor SERIAL PRIMARY KEY,
	nome VARCHAR(100) NOT NULL,
	cnpj VARCHAR (18) NOT NULL
);

CREATE TABLE Raca (
	cod_raca SERIAL PRIMARY KEY,
	nome_raca VARCHAR (50) NOT NULL,
	cod_animal INT NOT NULL,
	FOREIGN KEY (cod_animal) REFERENCES Animal (cod_animal)
);

CREATE TABLE Pet (
	cod_pet SERIAL PRIMARY KEY,
	nome VARCHAR (100) NOT NULL,
	porte VARCHAR (10) NOT NULL,
	tipo_pelo VARCHAR (10) NOT NULL,
	peso REAL NOT NULL,
	cod_animal INT NOT NULL,
	cod_cliente INT NOT NULL,
	FOREIGN KEY (cod_animal) REFERENCES Animal(cod_animal),
	FOREIGN KEY (cod_cliente) REFERENCES Cliente(cod_cliente)
);

CREATE TABLE Endereco (
	cod_endereco SERIAL PRIMARY KEY,
	nome_rua VARCHAR (100) NOT NULL,
	cep VARCHAR (8) NOT NULL,
	complemento VARCHAR (150),
	numero INT NOT NULL,
	cod_cliente INT NULL,
	cod_fornecedor INT NULL,
	FOREIGN KEY (cod_cliente) REFERENCES Cliente(cod_cliente),
	FOREIGN KEY (cod_fornecedor) REFERENCES Fornecedor(cod_fornecedor)
);

CREATE TABLE Telefone (
	cod_telefone SERIAL PRIMARY KEY,
	nome_responsavel VARCHAR (100) NOT NULL,
	numero VARCHAR (15) NOT NULL,
	cod_cliente INT NULL,
	cod_fornecedor INT NULL,
	FOREIGN KEY (cod_cliente) REFERENCES Cliente (cod_cliente),
	FOREIGN KEY (cod_fornecedor) REFERENCES Fornecedor (cod_fornecedor)
);

CREATE TABLE Estoque (
	cod_estoque SERIAL PRIMARY KEY,
	qtd_disponivel NUMERIC NOT NULL,
	qtd_bloqueada NUMERIC NOT NULL,
	qtd_avariada NUMERIC NOT NULL,
	cod_produto INT NOT NULL,
	FOREIGN KEY (cod_produto) REFERENCES Produto (cod_produto)
);

CREATE TABLE Atendimento (
	cod_atendimento SERIAL PRIMARY KEY,
	cod_pet INT NOT NULL,
	FOREIGN KEY (cod_pet) REFERENCES Pet(cod_pet)
);

CREATE TABLE Servico (
	cod_servico SERIAL PRIMARY KEY,
	nome_servico VARCHAR (50) NOT NULL,
	tipo_servico VARCHAR (100) NOT NULL,
	valor_servico NUMERIC NOT NULL,
	cod_empregado INT NOT NULL,
	FOREIGN KEY (cod_empregado) REFERENCES Empregado (cod_empregado)
);

CREATE TABLE Pedido (
	cod_pedido SERIAL PRIMARY KEY,
	observacao VARCHAR (150),
	cod_empregado INT NOT NULL,
	cod_pet INT NOT NULL,
	cod_cliente INT NOT NULL,
	data_pedido DATE NOT NULL,
	valor_total REAL NOT NULL,
	FOREIGN KEY (cod_empregado) REFERENCES Empregado (cod_empregado),
	FOREIGN KEY (cod_pet) REFERENCES Pet (cod_pet),
	FOREIGN KEY (cod_cliente) REFERENCES Cliente (cod_cliente)
);

CREATE TABLE Produto_pedido (
	cod_produto_cod_pedido SERIAL PRIMARY KEY,
	cod_produto INT NOT NULL,
	cod_pedido INT NOT NULL,
	qtd_produto NUMERIC NOT NULL,
	valor_unitario REAL NOT NULL,
	valor_total REAL NOT NULL,
	FOREIGN KEY (cod_produto) REFERENCES Produto (cod_produto),
	FOREIGN KEY (cod_pedido) REFERENCES Pedido (cod_pedido)
);

CREATE TABLE Produto_fornecedor (
	cod_produto_cod_fornecedor SERIAL PRIMARY KEY,
	preco_custo REAL NOT NULL,
	cod_produto INT NOT NULL,
	cod_fornecedor INT NOT NULL,
	FOREIGN KEY (cod_produto) REFERENCES Produto (cod_produto),
	FOREIGN KEY (cod_fornecedor) REFERENCES Fornecedor (cod_fornecedor)
);

CREATE TABLE Atendimento_servico(
	cod_atendimento_cod_servico SERIAL PRIMARY KEY,
	cod_atendimento INT NOT NULL,
	cod_servico INT NOT NULL,
	horario_inicio TIME NOT NULL,
	horario_fim TIME NOT NULL,
	agendamento DATE,
	FOREIGN KEY (cod_atendimento) REFERENCES Atendimento(cod_atendimento),
	FOREIGN KEY (cod_servico) REFERENCES Servico(cod_servico)
);

CREATE TABLE Empregado_atendimento(
	cod_empregado_cod_atendimento SERIAL PRIMARY KEY,
	cod_empregado INT NOT NULL,
	cod_atendimento INT NOT NULL,
	horario_inicio TIME NOT NULL,
	horario_fim TIME NOT NULL,
	FOREIGN KEY (cod_empregado) REFERENCES Empregado(cod_empregado),
	FOREIGN KEY (cod_atendimento) REFERENCES Atendimento(cod_atendimento)
);

